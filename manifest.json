{
  "manifest_version": 3,
  "name": "Robinhood Underdog Caddie",
  "version": "0.1.0",
  "description": "Live best ball exposure overlay for Underdog draft rooms.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://underdogfantasy.com/*",
    "https://*.underdogfantasy.com/*"
  ],
  "action": {
    "default_title": "Robinhood Underdog Caddie",
    "default_icon": {
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://underdogfantasy.com/*", "https://*.underdogfantasy.com/*"],
      "js": ["src/content.js"],
      "css": ["styles/overlay.css"],
      "run_at": "document_start"
    }
  ]
}
